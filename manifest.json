{
    "manifest_version": 3,
    "name": "Simple YouTube Ad Blocker",
    "version": "1.0.0",
    "description": "Automatically skips YouTube ads as soon as the skip button appears.",
    "permissions": ["storage"],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Ad Blocker Settings"
    },
    "content_scripts": [
        {
            "matches": ["*://*.youtube.com/*"],
            "js": ["content.js"],
            "all_frames": true,
            "run_at": "document_end"
        }
    ]
}
